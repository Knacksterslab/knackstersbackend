# ─── Knacksters Backend — Environment Variables ───────────────────────────────
# Copy this file to .env for local development.
# For production, set these as environment variables on your hosting platform.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development                          # production on server
FRONTEND_URL=http://localhost:3001            # https://www.knacksters.co on server

# ── Application Domains ───────────────────────────────────────────────────────
APP_NAME=Knacksters
API_DOMAIN=http://localhost:3000              # https://api.knacksters.co on server
WEBSITE_DOMAIN=http://localhost:3001          # https://www.knacksters.co on server

# ── Database (Supabase) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true&connection_limit=1

# ── SuperTokens ───────────────────────────────────────────────────────────────
SUPERTOKENS_CONNECTION_URI=https://YOUR-INSTANCE.aws.supertokens.io
SUPERTOKENS_API_KEY=your-supertokens-api-key
# Dashboard password — access at https://api.knacksters.co/api/auth/dashboard (prod)
SUPERTOKENS_DASHBOARD_KEY=your-dashboard-password

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Register at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs:
#   Dev:  http://localhost:3000/api/auth/callback/thirdparty
#   Prod: https://api.knacksters.co/api/auth/callback/thirdparty
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...                 # sk_live_... on server
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend (Transactional Email) ──────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Cal.com Webhook ───────────────────────────────────────────────────────────
CAL_COM_WEBHOOK_SECRET=your-calcom-webhook-secret

# ── Supabase Storage ──────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=your-secure-admin-password
